<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Kurdish Cinema Hub</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg-void: #03020a;
    --bg-deep: #080614;
    --bg-mid: #0e0c1e;
    --bg-card: rgba(18, 14, 36, 0.72);
    --border-subtle: rgba(255,255,255,0.06);
    --border-glow: rgba(140, 90, 255, 0.35);
    --accent-violet: #8b5cf6;
    --accent-indigo: #6366f1;
    --accent-cyan: #22d3ee;
    --accent-rose: #f43f5e;
    --accent-amber: #f59e0b;
    --text-primary: #f1eeff;
    --text-secondary: rgba(220,210,255,0.55);
    --text-dim: rgba(180,160,255,0.35);
    --glow-violet: rgba(139,92,246,0.25);
    --glow-cyan: rgba(34,211,238,0.2);
    --glow-rose: rgba(244,63,94,0.2);
    --radius-card: 20px;
    --radius-pill: 100px;
    --font-display: 'Syne', sans-serif;
    --font-body: 'DM Sans', sans-serif;
    --transition: 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg-void);
    color: var(--text-primary);
    font-family: var(--font-body);
    min-height: 100vh;
    overflow-x: hidden;
    -webkit-font-smoothing: antialiased;
  }

  /* ── BACKGROUND ATMOSPHERE ── */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 15% -10%, rgba(99,60,210,0.22) 0%, transparent 60%),
      radial-gradient(ellipse 60% 50% at 85% 110%, rgba(34,211,238,0.1) 0%, transparent 55%),
      radial-gradient(ellipse 40% 40% at 50% 50%, rgba(139,92,246,0.05) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* noise grain overlay */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.035'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    pointer-events: none;
    z-index: 0;
    opacity: 0.6;
  }

  /* ── NAV ── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 48px;
    height: 72px;
    background: linear-gradient(180deg, rgba(3,2,10,0.92) 0%, rgba(3,2,10,0) 100%);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-subtle);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .nav-logo-mark {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, var(--accent-violet), var(--accent-indigo));
    border-radius: 10px;
    display: grid;
    place-items: center;
    font-size: 18px;
    box-shadow: 0 0 18px rgba(139,92,246,0.5);
    flex-shrink: 0;
  }

  .nav-logo-text {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 17px;
    letter-spacing: -0.3px;
    color: var(--text-primary);
  }

  .nav-logo-text span {
    color: var(--accent-violet);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
    list-style: none;
  }

  .nav-links a {
    font-size: 13.5px;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    letter-spacing: 0.3px;
    transition: color var(--transition);
  }

  .nav-links a:hover { color: var(--text-primary); }
  .nav-links a.active { color: var(--accent-violet); }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .search-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-pill);
    padding: 8px 16px;
    transition: border-color var(--transition), background var(--transition);
    cursor: text;
  }

  .search-wrap:hover, .search-wrap:focus-within {
    border-color: var(--border-glow);
    background: rgba(139,92,246,0.08);
  }

  .search-wrap svg {
    width: 14px; height: 14px;
    opacity: 0.45;
    flex-shrink: 0;
  }

  .search-wrap input {
    background: none;
    border: none;
    outline: none;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: 13px;
    width: 160px;
    caret-color: var(--accent-violet);
  }

  .search-wrap input::placeholder { color: var(--text-dim); }

  .btn-avatar {
    width: 36px; height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, #7c3aed, #4f46e5);
    border: 2px solid rgba(139,92,246,0.4);
    cursor: pointer;
    display: grid;
    place-items: center;
    font-size: 14px;
    transition: box-shadow var(--transition);
  }

  .btn-avatar:hover {
    box-shadow: 0 0 18px rgba(139,92,246,0.5);
  }

  /* ── MAIN WRAPPER ── */
  main {
    position: relative;
    z-index: 1;
    padding-top: 72px;
  }

  /* ── HERO ── */
  .hero {
    position: relative;
    padding: 100px 48px 80px;
    overflow: hidden;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: rgba(139,92,246,0.12);
    border: 1px solid rgba(139,92,246,0.3);
    border-radius: var(--radius-pill);
    padding: 5px 14px 5px 9px;
    font-size: 11.5px;
    font-weight: 500;
    color: #b78df8;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 24px;
  }

  .hero-badge-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--accent-violet);
    box-shadow: 0 0 8px var(--accent-violet);
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(42px, 6vw, 76px);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -2px;
    max-width: 700px;
    margin-bottom: 20px;
  }

  .hero-title .line-accent {
    background: linear-gradient(90deg, var(--accent-violet), var(--accent-cyan));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: block;
  }

  .hero-subtitle {
    font-size: 16px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 460px;
    margin-bottom: 40px;
    letter-spacing: 0.2px;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 36px;
  }

  .stat {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    color: var(--text-primary);
  }

  .stat-label {
    font-size: 11px;
    font-weight: 500;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .stat-divider {
    width: 1px;
    height: 36px;
    background: var(--border-subtle);
  }

  /* hero decorative orbs */
  .hero-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    pointer-events: none;
  }

  .hero-orb-1 {
    width: 500px; height: 500px;
    right: -100px; top: -80px;
    background: radial-gradient(circle, rgba(99,60,210,0.18) 0%, transparent 70%);
  }

  .hero-orb-2 {
    width: 300px; height: 300px;
    right: 200px; bottom: -60px;
    background: radial-gradient(circle, rgba(34,211,238,0.1) 0%, transparent 70%);
  }

  /* ── SECTION ── */
  .section {
    padding: 0 48px 70px;
  }

  .section-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
  }

  .section-left {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .section-tag {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 4px 12px;
    border-radius: var(--radius-pill);
    border: 1px solid;
  }

  .tag-movies { color: #f59e0b; border-color: rgba(245,158,11,0.3); background: rgba(245,158,11,0.08); }
  .tag-dubbing { color: #22d3ee; border-color: rgba(34,211,238,0.3); background: rgba(34,211,238,0.08); }
  .tag-iptv { color: #f43f5e; border-color: rgba(244,63,94,0.3); background: rgba(244,63,94,0.08); }
  .tag-tools { color: #a78bfa; border-color: rgba(167,139,250,0.3); background: rgba(167,139,250,0.08); }

  .section-title {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.5px;
  }

  .section-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(90deg, var(--border-subtle) 0%, transparent 100%);
    margin-left: 20px;
  }

  .section-count {
    font-size: 12px;
    color: var(--text-dim);
    font-weight: 500;
  }

  /* ── GRID ── */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 22px;
  }

  /* ── CARD ── */
  .card {
    position: relative;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-card);
    padding: 32px 28px;
    cursor: pointer;
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 18px;
    overflow: hidden;
    transition: transform var(--transition), border-color var(--transition), box-shadow var(--transition);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    outline: none;
  }

  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-card);
    background: linear-gradient(135deg, rgba(255,255,255,0.04) 0%, transparent 60%);
    pointer-events: none;
    transition: opacity var(--transition);
  }

  .card::after {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: calc(var(--radius-card) + 1px);
    background: var(--card-glow, transparent);
    z-index: -1;
    opacity: 0;
    transition: opacity var(--transition);
    filter: blur(15px);
  }

  .card:hover {
    transform: translateY(-6px) scale(1.015);
    border-color: var(--card-accent, var(--border-glow));
    box-shadow:
      0 24px 60px rgba(0,0,0,0.5),
      0 0 0 1px var(--card-accent, var(--border-glow)),
      inset 0 1px 0 rgba(255,255,255,0.08);
  }

  .card:hover::after { opacity: 1; }

  .card:focus-visible {
    outline: 2px solid var(--accent-violet);
    outline-offset: 3px;
  }

  /* card colors */
  .card-violet {
    --card-accent: rgba(139,92,246,0.5);
    --card-glow: rgba(139,92,246,0.2);
    --card-icon-bg: linear-gradient(135deg, #7c3aed, #5b21b6);
    --card-icon-glow: rgba(139,92,246,0.6);
  }

  .card-cyan {
    --card-accent: rgba(34,211,238,0.5);
    --card-glow: rgba(34,211,238,0.15);
    --card-icon-bg: linear-gradient(135deg, #0891b2, #0e7490);
    --card-icon-glow: rgba(34,211,238,0.6);
  }

  .card-rose {
    --card-accent: rgba(244,63,94,0.5);
    --card-glow: rgba(244,63,94,0.15);
    --card-icon-bg: linear-gradient(135deg, #e11d48, #9f1239);
    --card-icon-glow: rgba(244,63,94,0.6);
  }

  .card-amber {
    --card-accent: rgba(245,158,11,0.5);
    --card-glow: rgba(245,158,11,0.15);
    --card-icon-bg: linear-gradient(135deg, #d97706, #92400e);
    --card-icon-glow: rgba(245,158,11,0.6);
  }

  .card-emerald {
    --card-accent: rgba(16,185,129,0.5);
    --card-glow: rgba(16,185,129,0.15);
    --card-icon-bg: linear-gradient(135deg, #059669, #065f46);
    --card-icon-glow: rgba(16,185,129,0.6);
  }

  .card-indigo {
    --card-accent: rgba(99,102,241,0.5);
    --card-glow: rgba(99,102,241,0.15);
    --card-icon-bg: linear-gradient(135deg, #4f46e5, #3730a3);
    --card-icon-glow: rgba(99,102,241,0.6);
  }

  /* card icon */
  .card-icon {
    width: 64px; height: 64px;
    border-radius: 16px;
    background: var(--card-icon-bg);
    display: grid;
    place-items: center;
    font-size: 28px;
    flex-shrink: 0;
    box-shadow: 0 8px 24px var(--card-icon-glow, rgba(0,0,0,0.3));
    transition: box-shadow var(--transition), transform var(--transition);
    line-height: 1;
  }

  .card:hover .card-icon {
    box-shadow: 0 12px 32px var(--card-icon-glow, rgba(0,0,0,0.4));
    transform: scale(1.08) rotate(-2deg);
  }

  .card-body { display: flex; flex-direction: column; gap: 6px; flex: 1; }

  .card-name {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.4px;
    color: var(--text-primary);
  }

  .card-desc {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.6;
    font-weight: 300;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 14px;
    border-top: 1px solid var(--border-subtle);
  }

  .card-tag {
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .card-arrow {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border-subtle);
    display: grid;
    place-items: center;
    transition: background var(--transition), border-color var(--transition), transform var(--transition);
    flex-shrink: 0;
  }

  .card-arrow svg {
    width: 12px; height: 12px;
    color: var(--text-secondary);
    transition: color var(--transition), transform var(--transition);
  }

  .card:hover .card-arrow {
    background: var(--card-accent, rgba(139,92,246,0.2));
    border-color: var(--card-accent, var(--border-glow));
    transform: scale(1.1);
  }

  .card:hover .card-arrow svg {
    color: var(--text-primary);
    transform: translate(1px, -1px);
  }

  /* shimmer on card edge */
  .card-shimmer {
    position: absolute;
    top: 0; left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(105deg, transparent 0%, rgba(255,255,255,0.03) 50%, transparent 100%);
    pointer-events: none;
    transition: left 0.6s ease;
  }

  .card:hover .card-shimmer { left: 150%; }

  /* ── DIVIDER ── */
  .section-divider {
    margin: 0 48px 60px;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--border-subtle), transparent);
  }

  /* ── FOOTER ── */
  footer {
    position: relative;
    z-index: 1;
    margin: 0 48px;
    padding: 32px 0;
    border-top: 1px solid var(--border-subtle);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .footer-logo-mark {
    width: 28px; height: 28px;
    background: linear-gradient(135deg, var(--accent-violet), var(--accent-indigo));
    border-radius: 8px;
    display: grid;
    place-items: center;
    font-size: 13px;
    opacity: 0.8;
  }

  .footer-brand {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    color: var(--text-secondary);
  }

  .footer-center {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--text-dim);
    font-weight: 400;
  }

  .footer-center svg {
    width: 14px; height: 14px;
    opacity: 0.5;
  }

  .footer-right {
    font-size: 11.5px;
    color: var(--text-dim);
    font-weight: 400;
    letter-spacing: 0.5px;
  }

  /* ── SCROLL ANIMATIONS ── */
  .fade-up {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .fade-up.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* stagger */
  .card:nth-child(1) { transition-delay: 0.05s; }
  .card:nth-child(2) { transition-delay: 0.10s; }
  .card:nth-child(3) { transition-delay: 0.15s; }
  .card:nth-child(4) { transition-delay: 0.20s; }
  .card:nth-child(5) { transition-delay: 0.25s; }
  .card:nth-child(6) { transition-delay: 0.30s; }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    nav { padding: 0 24px; }
    .nav-links { display: none; }
    .hero { padding: 80px 24px 60px; }
    .section { padding: 0 24px 50px; }
    .section-divider { margin: 0 24px 50px; }
    footer { margin: 0 24px; }
    .cards-grid { grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px; }
    .hero-stats { gap: 24px; }
  }

  @media (max-width: 600px) {
    .hero-title { letter-spacing: -1px; }
    .cards-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
    .card { padding: 22px 18px; gap: 14px; }
    .card-icon { width: 52px; height: 52px; font-size: 22px; border-radius: 12px; }
    .card-name { font-size: 16px; }
    .search-wrap { display: none; }
    .hero-stats { flex-wrap: wrap; gap: 16px; }
    .stat-divider { display: none; }
    footer { flex-direction: column; align-items: flex-start; }
    .footer-center { display: none; }
  }
</style>
</head>
<body>

<!-- ── NAV ── -->
<nav>
  <a class="nav-logo" href="#">
    <div class="nav-logo-mark">🎬</div>
    <span class="nav-logo-text">Kurdish <span>Cinema</span></span>
  </a>

  <ul class="nav-links">
    <li><a href="#" class="active">Browse</a></li>
    <li><a href="#">Movies</a></li>
    <li><a href="#">TV Series</a></li>
    <li><a href="#">Live</a></li>
    <li><a href="#">Subtitles</a></li>
  </ul>

  <div class="nav-right">
    <div class="search-wrap" tabindex="0">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35" stroke-linecap="round"/></svg>
      <input type="text" placeholder="Search Kurdish cinema…" aria-label="Search">
    </div>
    <div class="btn-avatar" role="button" aria-label="Profile">👤</div>
  </div>
</nav>

<!-- ── MAIN ── -->
<main>

  <!-- ── HERO ── -->
  <section class="hero">
    <div class="hero-orb hero-orb-1"></div>
    <div class="hero-orb hero-orb-2"></div>

    <div class="hero-badge">
      <div class="hero-badge-dot"></div>
      Now Streaming
    </div>

    <h1 class="hero-title">
      Kurdish
      <span class="line-accent">Cinema Hub</span>
    </h1>

    <p class="hero-subtitle">
      Your premium gateway to Kurdish cinema, series, documentaries, and live channels — all in one beautifully crafted portal.
    </p>

    <div class="hero-stats">
      <div class="stat">
        <span class="stat-value">6+</span>
        <span class="stat-label">Platforms</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">HD</span>
        <span class="stat-label">Quality</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">Free</span>
        <span class="stat-label">Access</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">24/7</span>
        <span class="stat-label">Live</span>
      </div>
    </div>
  </section>

